# ============================================
# .env.example - Plantilla de configuracion SIRA
# Copia este archivo como ".env" y reemplaza los
# valores de ejemplo por los reales de tu entorno.
# NUNCA subas el archivo ".env" real al repositorio.
# ============================================

# --------------------------------------------
# BASE DE DATOS (MySQL)
# --------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=usuario_ejemplo
DB_PASSWORD=contrasena_segura
DB_NAME=sira_db
DB_DIALECT=mysql

# --------------------------------------------
# SEGURIDAD / AUTENTICACION (JWT)
# --------------------------------------------
SECRET_KEY=tu_llave_secreta_muy_larga
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --------------------------------------------
# SERVIDOR / APLICACION
# --------------------------------------------
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# --------------------------------------------
# FRONTEND / CORS
# --------------------------------------------
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# --------------------------------------------
# CORREO ELECTRONICO (recuperacion de contrasena, notificaciones)
# --------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu_correo@gmail.com
MAIL_PASSWORD=tu_contrasena_de_aplicacion
MAIL_FROM=SIRA <no-reply@sira.com>

# --------------------------------------------
# ALMACENAMIENTO DE ARCHIVOS (documentos subidos)
# --------------------------------------------
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# --------------------------------------------
# LOGS
# --------------------------------------------
LOG_LEVEL=info
